generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int             @id @default(autoincrement())
  username        String          @unique
  password        String
  receivedInvites Invite[]        @relation("InviteReceiver")
  sentInvites     Invite[]        @relation("InviteSender")
  messages        Message[]
  projects        Project[]
  memberships     ProjectMember[]
  tasks           Task[]
  createdAt DateTime        @default(now())

  @@index([username,id])
}

model Project {
  id        Int             @id @default(autoincrement())
  uid       Int
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  invites   Invite[]
  messages  Message[]
  user      User            @relation(fields: [uid], references: [id], onDelete: Cascade)
  members   ProjectMember[]
  tasks     Task[]
}

model ProjectMember {
  id       Int      @id @default(autoincrement())
  uId      Int
  pId      Int
  joinedAt DateTime @default(now())
  project  Project  @relation(fields: [pId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [uId], references: [id], onDelete: Cascade)
  

  @@unique([uId, pId])
  @@index([pId])
  @@index([uId])
}

model Task {
  id        Int        @id @default(autoincrement())
  uid       Int
  pid       Int
  status    TodoStatus @default(TODO)
  title     String
  content   String     @default("")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  project   Project    @relation(fields: [pid], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [uid], references: [id], onDelete: Cascade)
}

model Message {
  id        Int      @id @default(autoincrement())
  sender    Int
  pid       Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [pid], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [sender], references: [id], onDelete: Cascade)
}

model Invite {
  id          Int          @id @default(autoincrement())
  sId         Int
  pId         Int
  oId         Int
  createdAt   DateTime     @default(now())
  respondedAt DateTime?
  status      InviteStatus @default(PENDING)
  owner       User         @relation("InviteReceiver", fields: [oId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [pId], references: [id], onDelete: Cascade)
  user        User         @relation("InviteSender", fields: [sId], references: [id], onDelete: Cascade)

  @@unique([pId, oId])
}



enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TodoStatus {
  COMPLETED
  WORKING
  TODO
}


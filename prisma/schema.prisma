// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TodoStatus {
  WORKING
  COMPLETED
  TODO
}

model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  password  String
  projects  Project[]
  tasks     Task[]
  messages  Message[]
}

model Project {
  id        Int        @id @default(autoincrement())
  uid       Int
  user      User       @relation(fields: [uid], references: [id], onDelete: Cascade)
  name      String
  invites   String[]   @default([])
  tasks     Task[]
  messages  Message[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Task {
  id        Int        @id @default(autoincrement())
  uid       Int
  user      User       @relation(fields: [uid], references: [id], onDelete: Cascade)
  pid       Int
  project   Project    @relation(fields: [pid], references: [id], onDelete: Cascade)
  status    TodoStatus @default(TODO)
  title     String
  content   String[]   @default([])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Message {
  id        Int      @id @default(autoincrement())
  sender    Int
  user      User     @relation(fields: [sender], references: [id], onDelete: Cascade)
  pid       Int
  project   Project  @relation(fields: [pid], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}